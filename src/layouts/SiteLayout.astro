---
import "../styles/global.css";
import Nav from "../components/Nav.astro";

const {
  title = "Cx",
  description = "Cx - systems programming without hostility.",
  wide = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>

<body class="min-h-screen antialiased">
<!-- Atmosphere overlays -->
<div class="cx-noise"></div>
<!-- Uncomment if you want scanlines globally -->
<!-- <div class="cx-scanlines"></div> -->

<div class="relative z-10">
  <Nav />
  <main class={wide ? "mx-auto max-w-[1400px] px-6 py-10" : "mx-auto max-w-6xl px-4 py-10"}>
    <slot />
  </main>
</div>
</body>
</html>
