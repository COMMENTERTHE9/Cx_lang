---
import "../styles/global.css";
import Nav from "../components/Nav.astro";

const {
  title = "Cx",
  description = "Cx - systems programming without hostility.",
  wide = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark" data-contrast="normal">
<head>
  <script is:inline>
    (() => {
      const root = document.documentElement;
      try {
        const theme = localStorage.getItem("cx_theme");
        const contrast = localStorage.getItem("cx_contrast");
        root.dataset.theme = theme === "light" ? "light" : "dark";
        root.dataset.contrast = contrast === "high" ? "high" : "normal";
      } catch {
        root.dataset.theme = "dark";
        root.dataset.contrast = "normal";
      }
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>

<body class="min-h-screen antialiased">
<!-- Atmosphere overlays -->
<div class="cx-noise"></div>
<!-- Uncomment if you want scanlines globally -->
<!-- <div class="cx-scanlines"></div> -->

<div class="relative z-10">
  <Nav />
  <main class={wide ? "mx-auto max-w-[1400px] px-6 py-10" : "mx-auto max-w-6xl px-4 py-10"}>
    <slot />
  </main>
</div>
<svg width="0" height="0" style="position:absolute">
  <filter id="cb-protanopia">
    <feColorMatrix type="matrix"
      values="0.567 0.433 0     0 0
              0.558 0.442 0     0 0
              0     0.242 0.758 0 0
              0     0     0     1 0" />
  </filter>

  <filter id="cb-deuteranopia">
    <feColorMatrix type="matrix"
      values="0.625 0.375 0     0 0
              0.70  0.30  0     0 0
              0     0.30  0.70  0 0
              0     0     0     1 0" />
  </filter>

  <filter id="cb-tritanopia">
    <feColorMatrix type="matrix"
      values="0.95  0.05  0     0 0
              0     0.433 0.567 0 0
              0     0.475 0.525 0 0
              0     0     0     1 0" />
  </filter>
</svg>
</body>
</html>
