// CX-117: exit-code-based JIT parity — f64 modulo (remainder).
// Scaled exact check: multiply remainder by 10 before casting to t32.
// This catches backend drift hidden by direct truncation (e.g. 1.9 → 1).
a: f64 = 10.0
b: f64 = 3.0
rem: f64 = a % b
scale: f64 = 10.0
product: f64 = rem * scale
n: t32 = product
assert_eq(n, 10)

x: f64 = 5.5
y: f64 = 2.0
rem2: f64 = x % y
product2: f64 = rem2 * scale
m: t32 = product2
assert_eq(m, 15)
