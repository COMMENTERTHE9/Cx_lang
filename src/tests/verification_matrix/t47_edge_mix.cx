enum Mode { Idle, Run }

// exclusive range should not match 10; inclusive singleton should
let a;
a = 10
when (a) {
    1..10   => print(111)
    10..=10 => print(222)
    _       => print(333)
}

// unknown arm should match directly
let b;
b = ?
when (b) {
    true    => print(1)
    false   => print(0)
    unknown => print(2)
}

// enum catchall should fire for the non-matching variant
let m;
m = Mode::Run
when (m) {
    Mode::Idle => print(7)
    _          => print(8)
}

// precedence: == binds before ||, and true || ? short-circuits to true
print(false == false || ?)

// unknown short-circuit: ? * 0 becomes 0, then 1 + 0 = 1
print(1 + ? * 0)
