---
import SiteLayout from "../layouts/SiteLayout.astro";
import ExperimentalBanner from "../components/ExperimentalBanner.astro";
import SectionHeader from "../components/SectionHeader.astro";
import CopyButton from "../components/CopyButton.astro";
import { SITE } from "../lib/site";

const featuresNow = [
  { name: "Functions", desc: "Stable in the interpreter. Direct calls lower in the JIT.", href: "/docs/functions" },
  { name: "Control flow", desc: "if/else and for lower. when JIT lowering is in progress.", href: "/docs/control-flow" },
  { name: "Structs and methods", desc: "Struct fields lower. Method calls stay in progress.", href: "/docs/structs-and-methods" },
  { name: "Arrays", desc: "Fixed-size arrays work. JIT read/write fixtures pass.", href: "/docs/arrays" },
  { name: "Generics", desc: "Stable in the interpreter. JIT work remains.", href: "/docs/generics" },
  { name: "Result<T>", desc: "Ok, Err, and ? work in the interpreter.", href: "/docs/error-handling" },
  { name: "Imports", desc: "#![imports] resolves multi-file programs.", href: "/docs/modules-and-imports" },
  { name: "Testing", desc: "#[test], --test, assert, assert_eq.", href: "/docs/testing" },
  { name: "Backend", desc: "Interpreter reference. Cranelift JIT active, parity-gated, incomplete.", href: "/docs/backend-status" },
];

const featuresLater = [
  { name: "Type inference", desc: "Local inference works. Broader inference is in progress.", href: "/docs/variables-and-assignment" },
  { name: "JIT gaps", desc: "when, methods, f64 ops, generics, Result, strings.", href: "/docs/backend-status" },
  { name: "strref surface", desc: "Boundary type. Constructor syntax is unsettled.", href: "/docs/data-types" },
  { name: "C interop", desc: "Post-0.1." },
  { name: "Standard library", desc: "Minimal core first." },
];

const hello = `name: str = "World"
age: t32 = 42
score: f64 = 9.8

print("Hello, {name}!")
print("Age: {age}")
print("Score: {score}")`;
---

<SiteLayout title="Cx" description="Cx is a compiled, GC-free systems language for game engines.">
  <div class="home-shell">
    <!-- HERO -->
    <section class="hero">
      <ExperimentalBanner />

      <div class="hero-grid">
        <div>
          <div class="hero-kicker cx-mono">Compiled. GC-free.</div>

          <h1 class="hero-title">
            Cx is a compiled, GC-free systems language for game engines.
          </h1>

          <p class="hero-sub">
            Cx is early. Expect breaks.
          </p>

          <div class="hero-ctas">
            <a class="btn btn-primary" href={SITE.docs}>Read Docs</a>
            <a class="btn btn-ghost" href={SITE.github} target="_blank" rel="noreferrer">GitHub</a>
          </div>

          <div class="hero-meta">
            <div class="meta-chip">
              <span class="cx-mono text-[11px]" style="color: var(--cx-text-2);">STATUS</span>
              <span class="cx-mono text-[11px]" style="color: var(--cx-text);">Release candidate</span>
            </div>
            <div class="meta-chip">
              <span class="cx-mono text-[11px]" style="color: var(--cx-text-2);">VERSION</span>
              <span class="cx-mono text-[11px]" style="color: var(--cx-text);">{SITE.version}</span>
            </div>
            <div class="meta-chip">
              <span class="cx-mono text-[11px]" style="color: var(--cx-text-2);">FOCUS</span>
              <span class="cx-mono text-[11px]" style="color: var(--cx-text);">Engines</span>
            </div>
          </div>
        </div>

        <div class="hero-card">
          <div class="code-head">
            <div class="dots">
              <span class="dot red"></span>
              <span class="dot yellow"></span>
              <span class="dot green"></span>
            </div>
            <div class="cx-mono text-[11px]" style="color: var(--cx-text-2);">hello.cx</div>
          </div>
          <!-- Source: origin/submain:examples/hello.cx -->
          <pre class="code"><code>{hello}</code></pre>
          <div class="hero-card-footer">
            <div class="cx-mono text-[11px]" style="color: var(--cx-text-2);">
              Build from source.
            </div>
            <a class="cx-mono text-[11px]" style="color: var(--cx-accent);" href={SITE.docs}>
              docs://introduction →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY -->
    <section class="home-sec">
      <SectionHeader
        n="01"
        title="What Cx is"
        subtitle="Interpreter reference. Cranelift JIT active, parity-gated, incomplete."
      />

      <div class="two-col">
        <div class="card">
          <div class="card-title cx-mono">THE CORE</div>
          <p class="card-body">
            No garbage collector. Explicit memory. Typed values. Small core.
          </p>
        </div>

        <div class="card">
          <div class="card-title cx-mono">THE STATUS</div>
          <p class="card-body">
            Interpreter is reference. Cranelift JIT is Phase 15 active: 155 fixtures,
            66 PASS, 89 SKIP, 0 PARITY_FAILs.
          </p>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="home-sec">
      <SectionHeader
        n="02"
        title="Features"
        subtitle="Interpreter surface is stable. JIT work remains."
      />

      <div class="feature-grid">
        <div class="card">
          <div class="card-title cx-mono">NOW</div>
          <div class="feat-list">
            {featuresNow.map((f) => (
              f.href ? (
                <a class="feat feat-link" href={f.href}>
                  <div class="feat-name">{f.name}</div>
                  <div class="feat-desc">{f.desc}</div>
                </a>
              ) : (
                <div class="feat">
                  <div class="feat-name">{f.name}</div>
                  <div class="feat-desc">{f.desc}</div>
                </div>
              )
            ))}
          </div>
        </div>

        <div class="card">
          <div class="card-title cx-mono">LATER / IN PROGRESS</div>
          <div class="feat-list">
            {featuresLater.map((f) => (
              f.href ? (
                <a class="feat feat-link" href={f.href}>
                  <div class="feat-name">{f.name}</div>
                  <div class="feat-desc">{f.desc}</div>
                </a>
              ) : (
                <div class="feat">
                  <div class="feat-name">{f.name}</div>
                  <div class="feat-desc">{f.desc}</div>
                </div>
              )
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- INSTALL -->
    <section class="home-sec">
      <SectionHeader
        n="03"
        title="Build From Source"
        subtitle="Cx is early. Expect breaks."
      />

      <div class="card">
        <div class="install-head">
          <div class="cx-mono text-[11px]" style="color: var(--cx-text-2);">
            {SITE.clone}
          </div>
          <CopyButton value={SITE.clone} label="COPY" />
        </div>

        <pre class="code"><code>{`# clone
${SITE.clone}
cd Cx_lang

# build with JIT feature
cargo build --features jit

# run interpreter
cargo run -- examples/hello.cx

# run Cranelift JIT
cargo run --features jit -- --backend=cranelift examples/hello.cx`}</code></pre>

        <div class="mt-3 text-sm" style="color: var(--cx-text-2);">
          Matches current submain README.
        </div>
      </div>
    </section>

    <!-- ROADMAP + GITHUB -->
    <section class="home-sec">
      <SectionHeader
        n="04"
        title="Roadmap & GitHub"
        subtitle="The repo is the roadmap."
      />

      <div class="two-col">
        <div class="card">
          <div class="card-title cx-mono">ROADMAP</div>
          <ul class="road">
            <li><span class="road-dot"></span><a href="/docs/backend-status">Cranelift JIT parity coverage</a></li>
            <li><span class="road-dot"></span><a href="/docs/variables-and-assignment">Type inference beyond local bindings</a></li>
            <li><span class="road-dot"></span><a href="/docs/data-types">strref and string boundary layout</a></li>
            <li><span class="road-dot"></span> C interop after 0.1</li>
            <li><span class="road-dot"></span> Minimal standard library</li>
          </ul>
        </div>

        <div class="card">
          <div class="card-title cx-mono">GITHUB</div>
          <p class="card-body">
            Repo is source of truth: commits, issues, implementation status.
          </p>

          <div class="mt-4 flex flex-wrap gap-3">
            <a class="btn btn-primary" href={SITE.github} target="_blank" rel="noreferrer">Open Repo</a>
            <CopyButton value={SITE.clone} label="COPY CLONE" />
          </div>

          <div class="mt-4 cx-mono text-[11px]" style="color: var(--cx-text-2);">
            {SITE.github}
          </div>
        </div>
      </div>
    </section>

    <footer class="home-foot">
      <div class="cx-mono text-[11px]" style="color: var(--cx-text-2);">
        Cx is early. Expect breaks.
      </div>
      <div class="foot-links">
        <a href={SITE.docs}>Docs</a>
        <a href={SITE.blog}>Blog</a>
        <a href={SITE.github} target="_blank" rel="noreferrer">GitHub</a>
      </div>
    </footer>
  </div>

  <style>
    .home-shell{
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
      min-width: 0;
    }

    .hero{ margin-top: 18px; }

    .hero-grid{
      margin-top: 18px;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 24px;
      align-items: start;
      min-width: 0;
    }

    .hero-kicker{
      letter-spacing: .12em;
      font-size: 11px;
      color: var(--cx-text-2);
      margin-top: 10px;
    }

    .hero-title{
      font-family: var(--cx-display);
      font-size: 64px;
      line-height: .92;
      margin: 12px 0 0;
      color: var(--cx-text);
      max-width: 20ch;
      overflow-wrap: normal;
    }

    .hero-sub{
      margin-top: 14px;
      font-size: 15px;
      color: var(--cx-text-2);
      max-width: 80ch;
      line-height: 1.6;
    }

    .hero-ctas{ display:flex; gap: 12px; margin-top: 18px; flex-wrap:wrap; }

    .btn{
      display:inline-flex; align-items:center; justify-content:center;
      padding: 10px 14px;
      border-radius: 14px;
      border: 1px solid var(--cx-border);
      text-decoration:none;
      font-family: var(--cx-mono);
      font-size: 12px;
      letter-spacing: .08em;
      transition: 140ms ease;
    }
    .btn-primary{
      border-color: color-mix(in srgb, var(--cx-accent) 60%, var(--cx-border));
      background: color-mix(in srgb, var(--cx-accent) 14%, var(--cx-surface));
      color: var(--cx-text);
      box-shadow: 0 0 30px color-mix(in srgb, var(--cx-accent) 14%, transparent);
    }
    .btn-primary:hover{
      border-color: color-mix(in srgb, var(--cx-accent) 80%, var(--cx-border));
      box-shadow: 0 0 42px color-mix(in srgb, var(--cx-accent) 18%, transparent);
    }
    .btn-ghost{
      background: color-mix(in srgb, var(--cx-surface) 70%, transparent);
      color: var(--cx-text);
    }
    .btn-ghost:hover{
      border-color: color-mix(in srgb, var(--cx-text) 22%, var(--cx-border));
    }

    .hero-meta{
      margin-top: 16px;
      display:flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .meta-chip{
      display:flex; gap: 8px; align-items:center;
      min-width: 0;
      padding: 8px 10px;
      border-radius: 999px;
      border: 1px solid var(--cx-border);
      background: color-mix(in srgb, var(--cx-surface) 75%, transparent);
    }

    .hero-card{
      min-width: 0;
      border-radius: 18px;
      border: 1px solid var(--cx-border);
      background: color-mix(in srgb, var(--cx-surface-2) 82%, transparent);
      overflow: hidden;
      box-shadow: 0 20px 70px rgba(0,0,0,.40);
    }

    .code-head{
      display:flex; align-items:center; justify-content:space-between;
      padding: 10px 12px;
      border-bottom: 1px solid var(--cx-border);
      background: color-mix(in srgb, var(--cx-surface) 80%, transparent);
    }
    .dots{ display:flex; gap: 6px; }
    .dot{ width: 10px; height: 10px; border-radius: 50%; opacity: .9; }
    .dot.red{ background: #ff5f57; }
    .dot.yellow{ background: #febc2e; }
    .dot.green{ background: #28c840; }

    .code{
      max-width: 100%;
      margin: 0;
      padding: 14px;
      font-family: var(--cx-mono);
      font-size: 12px;
      color: var(--cx-text);
      background: rgba(0,0,0,.18);
      overflow:auto;
    }
    .hero-card-footer{
      display:flex; justify-content:space-between; gap: 10px; flex-wrap:wrap;
      padding: 10px 12px;
      border-top: 1px solid var(--cx-border);
      background: color-mix(in srgb, var(--cx-surface) 80%, transparent);
    }

    .home-sec{ margin-top: 54px; }

    .two-col{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      min-width: 0;
    }

    .feature-grid{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      min-width: 0;
    }

    .card{
      min-width: 0;
      border: 1px solid var(--cx-border);
      background: color-mix(in srgb, var(--cx-surface) 70%, transparent);
      border-radius: 18px;
      padding: 16px;
    }
    .card-title{
      letter-spacing: .14em;
      font-size: 11px;
      color: var(--cx-text-2);
      margin-bottom: 10px;
    }
    .card-body{
      margin: 0;
      font-size: 14px;
      color: var(--cx-text-2);
      line-height: 1.7;
      max-width: 85ch;
    }

    .feat-list{ display:grid; gap: 12px; }
    .feat{
      display: block;
      padding: 10px;
      border: 1px solid transparent;
      border-radius: 12px;
      text-decoration: none;
    }
    .feat-link:hover{
      border-color: color-mix(in srgb, var(--cx-accent) 35%, var(--cx-border));
      background: color-mix(in srgb, var(--cx-accent) 7%, transparent);
    }
    .feat-name{
      font-family: var(--cx-display);
      font-size: 22px;
      line-height: 1.05;
      color: var(--cx-text);
    }
    .feat-desc{
      margin-top: 4px;
      font-size: 13px;
      color: var(--cx-text-2);
      line-height: 1.55;
      max-width: 80ch;
    }

    .install-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 10px;
      flex-wrap: wrap;
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid var(--cx-border);
      background: color-mix(in srgb, var(--cx-surface-2) 55%, transparent);
      margin-bottom: 12px;
    }
    .install-head > div{
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .road{ margin: 0; padding-left: 0; list-style: none; display:grid; gap: 10px; }
    .road li{ color: var(--cx-text-2); font-size: 14px; display:flex; gap: 10px; align-items:center; }
    .road a{ color: inherit; text-decoration: none; }
    .road a:hover{ color: var(--cx-text); }
    .road-dot{
      width: 10px; height: 10px; border-radius: 50%;
      background: color-mix(in srgb, var(--cx-accent) 55%, var(--cx-border));
      box-shadow: 0 0 18px color-mix(in srgb, var(--cx-accent) 18%, transparent);
    }

    .home-foot{
      margin: 60px 0 40px;
      padding-top: 18px;
      border-top: 1px solid var(--cx-border);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 12px;
      flex-wrap: wrap;
    }
    .foot-links{ display:flex; gap: 14px; }
    .foot-links a{
      color: var(--cx-text-2);
      text-decoration:none;
      font-family: var(--cx-mono);
      font-size: 12px;
    }
    .foot-links a:hover{ color: var(--cx-text); }

    @media (max-width: 980px){
      .hero-grid{ grid-template-columns: 1fr; }
      .hero-title{ font-size: 54px; }
      .two-col{ grid-template-columns: 1fr; }
      .feature-grid{ grid-template-columns: 1fr; }
    }

    @media (max-width: 640px){
      .home-shell{ padding: 0; }
      .hero-title{ font-size: 44px; max-width: 100%; }
      .hero-sub{ max-width: 100%; }
      .code,
      .code code{
        white-space: pre-wrap;
        overflow-wrap: anywhere;
      }
      .hero-card-footer{ align-items: flex-start; }
      .hero-card-footer a{ overflow-wrap: anywhere; }
      .road li{ align-items: flex-start; }
      .home-foot{ align-items: flex-start; }
    }

    @media (max-width: 380px){
      .hero-title{ font-size: 40px; }
      .meta-chip{ width: 100%; justify-content: space-between; }
    }
  </style>
</SiteLayout>
