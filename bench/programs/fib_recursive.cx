// Recursive Fibonacci. Stresses Cx function-call overhead — the native
// Rust recursion path (call_semantic_func -> run_semantic_stmt ->
// eval_semantic_expr) that requires the 64 MB interpreter stack.
fnc: t64 fib(n: t64) {
    if n < 2 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

print(fib(30))
